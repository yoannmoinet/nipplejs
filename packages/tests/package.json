{
    "name": "@nipple/tests",
    "packageManager": "yarn@4.13.0",
    "license": "MIT",
    "private": true,
    "author": "yoannmoinet",
    "description": "Tests for NippleJS.",
    "homepage": "https://github.com/yoannmoinet/nipplejs/tree/main/packages/tests#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/yoannmoinet/nipplejs",
        "directory": "packages/tests"
    },
    "exports": {
        "./*": "./src/*.ts",
        "./_jest/fixtures/*": "./src/_jest/fixtures/*",
        "./_jest/helpers/*": "./src/_jest/helpers/*.ts"
    },
    "scripts": {
        "build": "yarn clean && tsc",
        "clean": "rm -rf dist",
        "test:e2e": "FORCE_COLOR=true playwright test",
        "test:unit": "FORCE_COLOR=true JEST_CONFIG_TRANSPILE_ONLY=true NODE_OPTIONS=\"--openssl-legacy-provider --experimental-vm-modules ${NODE_OPTIONS:-}\" jest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "nipplejs": "workspace:*"
    },
    "devDependencies": {
        "@nipple/tools": "workspace:*",
        "@playwright/test": "1.49.1",
        "@rollup/plugin-commonjs": "28.0.1",
        "@rollup/plugin-node-resolve": "15.3.0",
        "@types/jest": "29.5.12",
        "@types/node": "^22",
        "@types/web": "0.0.206",
        "esbuild": "0.24.0",
        "glob": "11.0.0",
        "jest": "29.7.0",
        "jest-environment-jsdom": "29.7.0",
        "memfs": "4.9.2",
        "nock": "14.0.0-beta.7",
        "rollup": "4.24.2",
        "rollup-plugin-esbuild": "6.1.1",
        "ts-jest": "29.1.2",
        "typescript": "5.4.3"
    }
}
