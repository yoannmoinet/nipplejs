---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import MobileNav from '../components/MobileNav.astro';

interface Props {
  frontmatter?: {
    title?: string;
    description?: string;
  };
  headings?: Array<{ depth: number; slug: string; text: string }>;
}

const { frontmatter = {}, headings = [] } = Astro.props;
const title = frontmatter.title ? `${frontmatter.title} — NippleJS` : 'NippleJS Docs';
const description = frontmatter.description ?? 'NippleJS documentation';
---
<BaseLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center gap-2 md:hidden py-2">
      <MobileNav />
      {frontmatter.title && (
        <span class="text-heading text-sm font-semibold truncate">{frontmatter.title}</span>
      )}
    </div>
    <div class="flex min-h-[calc(100vh-3.5rem)]">
      <Sidebar />
      <article class="docs-prose flex-1 min-w-0 py-8 md:px-8">
        <slot />
      </article>
      <TableOfContents headings={headings} />
    </div>
  </div>
</BaseLayout>

<style>
  /* Prose styling for MDX content */
  .docs-prose :global(h1) {
    color: var(--color-heading);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .docs-prose :global(h2) {
    color: var(--color-heading);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-prose :global(h3) {
    color: var(--color-heading);
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .docs-prose :global(h4) {
    color: var(--color-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .docs-prose :global(p) {
    color: var(--color-body);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .docs-prose :global(a) {
    color: var(--color-accent-indigo);
    text-decoration: none;
    transition: color 0.15s;
  }

  .docs-prose :global(a:hover) {
    color: var(--color-heading);
  }

  .docs-prose :global(strong) {
    color: var(--color-heading);
    font-weight: 600;
  }

  .docs-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-accent-indigo);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
  }

  .docs-prose :global(pre) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .docs-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .docs-prose :global(ul),
  .docs-prose :global(ol) {
    color: var(--color-body);
    line-height: 1.75;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .docs-prose :global(ul) {
    list-style: disc;
  }

  .docs-prose :global(ol) {
    list-style: decimal;
  }

  .docs-prose :global(li) {
    margin-bottom: 0.25rem;
  }

  .docs-prose :global(li code) {
    font-size: 0.85em;
  }

  .docs-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent-indigo);
    padding-left: 1rem;
    margin-bottom: 1rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .docs-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .docs-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .docs-prose :global(th) {
    color: var(--color-heading);
    font-weight: 600;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .docs-prose :global(td) {
    color: var(--color-body);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
</style>
