---
import BaseLayout from '../layouts/BaseLayout.astro';
import JoystickDemo from '../components/JoystickDemo.astro';

const base = import.meta.env.BASE_URL;

const games = [
  {
    name: 'Neon Snake',
    slug: 'fog-explorer',
    description: 'Collect orbs to grow your glowing snake.',
    highlights: ['mode'],
    badges: ["mode: 'static'"],
  },
  {
    name: 'Asteroid Dodge',
    slug: 'asteroid-dodge',
    description: 'Dodge falling asteroids with horizontal-only movement.',
    highlights: ['lockX'],
    badges: ["lockX: true"],
  },
  {
    name: 'Dual-Stick Arena',
    slug: 'dual-stick-arena',
    description: 'Move and shoot with two joysticks. Best on mobile.',
    highlights: ['multitouch'],
    badges: ["multitouch: true"],
  },
  {
    name: 'Space Observatory',
    slug: 'endless-chase',
    description: 'Aim within the joystick, pan the sky by pushing beyond — two controls, one thumb.',
    highlights: ['follow'],
    badges: ['follow: true', 'baseDelta'],
  },
  {
    name: 'Space Drift',
    slug: 'space-drift',
    description: 'Set your heading and drift through space.',
    highlights: ['restJoystick'],
    badges: ["restJoystick: false"],
  },
];
---
<BaseLayout title="NippleJS — Virtual Joystick">
  <main class="max-w-5xl mx-auto px-6">

    <!-- Hero -->
    <section class="text-center py-28 relative">
      <!-- Logo with particles emitted from text -->
      <div class="flex items-center justify-center gap-5 mb-10 relative" id="hero-logo">
        <canvas id="logo-particles" class="absolute inset-0 w-full h-full pointer-events-none" style="z-index:0;"></canvas>
        <div class="relative z-[1] flex items-center gap-5">
          <div id="hero-joystick-back" class="w-28 h-28 rounded-full relative flex items-center justify-center" style="background: rgba(99,102,241,0.2);">
            <div id="hero-joystick-front" class="w-14 h-14 rounded-full absolute" style="background: rgba(129,140,248,0.7); transition: transform 0.1s ease-out;"></div>
          </div>
          <span id="logo-text" class="text-heading font-bold text-6xl tracking-tight" style="text-shadow: 0 0 20px rgba(129,140,248,0.4), 0 0 40px rgba(99,102,241,0.2);">nipplejs</span>
        </div>
      </div>

      <script>
        // --- Particles emitted from the text bounding box ---
        const logoCanvas = document.getElementById('logo-particles') as HTMLCanvasElement;
        const logoText = document.getElementById('logo-text');
        const logoContainer = document.getElementById('hero-logo');
        if (logoCanvas && logoText && logoContainer) {
          const lctx = logoCanvas.getContext('2d')!;
          const colors = ['#818cf8', '#38bdf8', '#a78bfa', '#c7d2fe'];

          function resizeLogoCanvas() {
            const rect = logoContainer!.getBoundingClientRect();
            logoCanvas.width = rect.width;
            logoCanvas.height = rect.height;
          }
          resizeLogoCanvas();
          window.addEventListener('resize', resizeLogoCanvas);

          interface Particle {
            x: number; y: number;
            vx: number; vy: number;
            size: number; alpha: number;
            color: string; decay: number;
          }
          const parts: Particle[] = [];

          function getTextRect() {
            const containerRect = logoContainer!.getBoundingClientRect();
            const textRect = logoText!.getBoundingClientRect();
            return {
              x: textRect.left - containerRect.left,
              y: textRect.top - containerRect.top,
              w: textRect.width,
              h: textRect.height,
            };
          }

          function spawn() {
            const r = getTextRect();
            // Spawn along the edges and surface of the text
            const x = r.x + Math.random() * r.w;
            const y = r.y + Math.random() * r.h;

            parts.push({
              x,
              y,
              vx: (Math.random() - 0.5) * 0.08,
              vy: -(0.03 + Math.random() * 0.08),
              size: 0.5 + Math.random() * 1.5,
              alpha: 0.2 + Math.random() * 0.35,
              color: colors[Math.floor(Math.random() * colors.length)],
              decay: 0.0008 + Math.random() * 0.001,
            });
          }

          let f = 0;
          let logoVisible = true;
          let logoAnimId: number | null = null;

          function loop() {
            if (!logoVisible) { logoAnimId = null; return; }
            lctx.clearRect(0, 0, logoCanvas.width, logoCanvas.height);
            if (f % 4 === 0) spawn();

            for (let i = parts.length - 1; i >= 0; i--) {
              const p = parts[i];
              p.x += p.vx;
              p.y += p.vy;
              p.alpha -= p.decay;
              if (p.alpha <= 0) { parts.splice(i, 1); continue; }

              lctx.save();
              lctx.globalAlpha = p.alpha;
              lctx.shadowBlur = 6;
              lctx.shadowColor = p.color;
              lctx.fillStyle = p.color;
              lctx.beginPath();
              lctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
              lctx.fill();
              lctx.restore();
            }
            f++;
            logoAnimId = requestAnimationFrame(loop);
          }

          const logoObserver = new IntersectionObserver((entries) => {
            logoVisible = entries[0].isIntersecting;
            if (logoVisible && !logoAnimId) loop();
          });
          logoObserver.observe(logoContainer);
          loop();

          // --- Joystick front follows cursor ---
          const back = document.getElementById('hero-joystick-back');
          const front = document.getElementById('hero-joystick-front');
          if (back && front) {
            const maxDist = back.offsetWidth / 2; // front center can reach the back's edge
            document.addEventListener('mousemove', (e) => {
              const rect = back.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              const dx = e.clientX - cx;
              const dy = e.clientY - cy;
              const dist = Math.sqrt(dx * dx + dy * dy);
              const clamp = Math.min(dist, maxDist) / (dist || 1);
              front.style.transform = `translate(${dx * clamp}px, ${dy * clamp}px)`;
            });
            document.addEventListener('mouseleave', () => {
              front.style.transform = 'translate(0px, 0px)';
            });
          }
        }
      </script>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight leading-tight">
        <span class="hero-title block relative" data-text="Virtual joysticks">
          <span class="hero-title-text">Virtual joysticks</span>
        </span>
        <span class="hero-title block relative mt-2" data-text="for the modern web">
          <span class="hero-title-text">for the modern web</span>
        </span>
      </h1>
      <p class="mt-6 font-mono text-sm text-muted">
        // zero deps &middot; typescript &middot; touch &amp; mouse
      </p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href={`${base}getting-started`}
          class="inline-flex items-center px-6 py-3 rounded-full bg-gradient-to-r from-accent-indigo to-accent-cyan text-white font-semibold text-sm shadow-[0_0_24px_rgba(99,102,241,0.4)] hover:shadow-[0_0_32px_rgba(99,102,241,0.6)] transition-shadow"
        >
          Get Started &rarr;
        </a>
        <span class="glass inline-flex items-center px-5 py-3 rounded-full font-mono text-sm text-muted border border-border">
          npm i nipplejs
        </span>
      </div>
    </section>

    <!-- Stats -->
    <section class="flex flex-col sm:flex-row gap-4 justify-center mb-24">
      <div class="glass flex-1 p-6 text-center">
        <div class="flex items-center justify-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-indigo shadow-[0_0_8px_rgba(129,140,248,0.8)]"></span>
          <span class="font-mono text-4xl font-bold text-heading" style="text-shadow: 0 0 20px rgba(129,140,248,0.6);">3</span>
        </div>
        <p class="mt-2 text-xs uppercase tracking-widest text-muted">Modes</p>
      </div>
      <div class="glass flex-1 p-6 text-center">
        <div class="flex items-center justify-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-cyan shadow-[0_0_8px_rgba(56,189,248,0.8)]"></span>
          <span class="font-mono text-4xl font-bold text-heading" style="text-shadow: 0 0 20px rgba(56,189,248,0.6);">0</span>
        </div>
        <p class="mt-2 text-xs uppercase tracking-widest text-muted">Dependencies</p>
      </div>
      <div class="glass flex-1 p-6 text-center">
        <div class="flex items-center justify-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-purple shadow-[0_0_8px_rgba(167,139,250,0.8)]"></span>
          <span class="font-mono text-4xl font-bold text-heading" style="text-shadow: 0 0 20px rgba(167,139,250,0.6);">TS</span>
        </div>
        <p class="mt-2 text-xs uppercase tracking-widest text-muted">Native</p>
      </div>
    </section>

    <!-- Games Showcase -->
    <section class="space-y-16 pb-24">
      {games.map((game) => (
        <div>
          <h3 class="text-heading text-2xl font-bold mb-2">{game.name}</h3>
          <p class="text-body mb-3">{game.description}</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {game.badges.map((badge) => (
              <span class="glass px-3 py-1 text-xs font-mono text-muted">{badge}</span>
            ))}
          </div>
          <JoystickDemo game={game.slug} highlight={game.highlights} />
        </div>
      ))}
    </section>

  </main>
</BaseLayout>
