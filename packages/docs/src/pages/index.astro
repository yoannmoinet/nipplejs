---
import BaseLayout from '../layouts/BaseLayout.astro';
import JoystickDemo from '../components/JoystickDemo.astro';

const base = import.meta.env.BASE_URL;

const games = [
  {
    name: 'Neon Snake',
    slug: 'fog-explorer',
    description: 'Collect orbs to grow your glowing snake.',
    highlights: ['mode'],
    badges: ["mode: 'static'"],
  },
  {
    name: 'Asteroid Dodge',
    slug: 'asteroid-dodge',
    description: 'Dodge falling asteroids with horizontal-only movement.',
    highlights: ['lockX'],
    badges: ["lockX: true"],
  },
  {
    name: 'Dual-Stick Arena',
    slug: 'dual-stick-arena',
    description: 'Move and shoot with two joysticks. Best on mobile.',
    highlights: ['multitouch'],
    badges: ["multitouch: true"],
  },
  {
    name: 'Space Observatory',
    slug: 'endless-chase',
    description: 'Aim within the joystick, pan the sky by pushing beyond — two controls, one thumb.',
    highlights: ['follow'],
    badges: ['follow: true', 'baseDelta'],
  },
  {
    name: 'Space Drift',
    slug: 'space-drift',
    description: 'Set your heading and drift through space.',
    highlights: ['restJoystick'],
    badges: ["restJoystick: false"],
  },
];
---
<BaseLayout title="NippleJS — Virtual Joystick">
  <main class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Hero -->
    <section class="text-center py-16 sm:py-28 relative">
      <!-- Logo with particles emitted from text -->
      <div class="flex items-center justify-center mb-8 sm:mb-10 relative" id="hero-logo">
        <canvas id="logo-particles" class="absolute inset-0 w-full h-full pointer-events-none" style="z-index:0;"></canvas>
        <div class="relative z-[1] flex items-center gap-3 sm:gap-5">
          <div id="hero-joystick-back" class="w-16 h-16 sm:w-28 sm:h-28 rounded-full relative flex items-center justify-center shrink-0" style="background: rgba(99,102,241,0.2);">
            <div id="hero-joystick-front" class="w-8 h-8 sm:w-14 sm:h-14 rounded-full absolute" style="background: linear-gradient(135deg, #a5b4fc, #6366f1); transition: transform 0.1s ease-out;"></div>
          </div>
          <span id="logo-text" class="text-heading font-bold text-3xl sm:text-6xl tracking-tight" style="text-shadow: 0 0 20px rgba(129,140,248,0.4), 0 0 40px rgba(99,102,241,0.2);">nipplejs</span>
        </div>
      </div>

      <script>
        // --- Particles emitted from the text bounding box ---
        const logoCanvas = document.getElementById('logo-particles') as HTMLCanvasElement;
        const logoText = document.getElementById('logo-text');
        const logoContainer = document.getElementById('hero-logo');
        const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        if (logoCanvas && logoText && logoContainer && !isTouchDevice) {
          const lctx = logoCanvas.getContext('2d')!;
          const colors = ['#818cf8', '#38bdf8', '#a78bfa', '#c7d2fe'];

          function resizeLogoCanvas() {
            const rect = logoContainer!.getBoundingClientRect();
            logoCanvas.width = rect.width;
            logoCanvas.height = rect.height;
          }
          resizeLogoCanvas();
          window.addEventListener('resize', resizeLogoCanvas);

          interface Particle {
            x: number; y: number;
            vx: number; vy: number;
            size: number; alpha: number;
            color: string; decay: number;
          }
          const parts: Particle[] = [];

          function getTextRect() {
            const containerRect = logoContainer!.getBoundingClientRect();
            const textRect = logoText!.getBoundingClientRect();
            return {
              x: textRect.left - containerRect.left,
              y: textRect.top - containerRect.top,
              w: textRect.width,
              h: textRect.height,
            };
          }

          function spawn() {
            const r = getTextRect();
            // Spawn along the edges and surface of the text
            const x = r.x + Math.random() * r.w;
            const y = r.y + Math.random() * r.h;

            parts.push({
              x,
              y,
              vx: (Math.random() - 0.5) * 0.08,
              vy: -(0.03 + Math.random() * 0.08),
              size: 0.5 + Math.random() * 1.5,
              alpha: 0.2 + Math.random() * 0.35,
              color: colors[Math.floor(Math.random() * colors.length)],
              decay: 0.0008 + Math.random() * 0.001,
            });
          }

          let f = 0;
          let logoVisible = true;
          let logoAnimId: number | null = null;

          function loop() {
            if (!logoVisible) { logoAnimId = null; return; }
            lctx.clearRect(0, 0, logoCanvas.width, logoCanvas.height);
            if (f % 4 === 0) spawn();

            for (let i = parts.length - 1; i >= 0; i--) {
              const p = parts[i];
              p.x += p.vx;
              p.y += p.vy;
              p.alpha -= p.decay;
              if (p.alpha <= 0) { parts.splice(i, 1); continue; }

              lctx.save();
              lctx.globalAlpha = p.alpha;
              lctx.shadowBlur = 6;
              lctx.shadowColor = p.color;
              lctx.fillStyle = p.color;
              lctx.beginPath();
              lctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
              lctx.fill();
              lctx.restore();
            }
            f++;
            logoAnimId = requestAnimationFrame(loop);
          }

          const logoObserver = new IntersectionObserver((entries) => {
            logoVisible = entries[0].isIntersecting;
            if (logoVisible && !logoAnimId) loop();
          });
          logoObserver.observe(logoContainer);
          loop();

          // --- Joystick front follows cursor (desktop only) ---
          const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
          const back = document.getElementById('hero-joystick-back');
          const front = document.getElementById('hero-joystick-front');
          if (back && front && !isTouch) {
            const maxDist = back.offsetWidth / 2; // front center can reach the back's edge
            document.addEventListener('mousemove', (e) => {
              const rect = back.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              const dx = e.clientX - cx;
              const dy = e.clientY - cy;
              const dist = Math.sqrt(dx * dx + dy * dy);
              const clamp = Math.min(dist, maxDist) / (dist || 1);
              front.style.transform = `translate(${dx * clamp}px, ${dy * clamp}px)`;
            });
            document.addEventListener('mouseleave', () => {
              front.style.transform = 'translate(0px, 0px)';
            });
          }
        }
      </script>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight leading-tight">
        <span class="hero-title block relative" data-text="Virtual joysticks">
          <span class="hero-title-text">Virtual joysticks</span>
        </span>
        <span class="hero-title block relative mt-2" data-text="for the modern web">
          <span class="hero-title-text">for the modern web</span>
        </span>
      </h1>
      <p class="mt-6 font-mono text-sm text-muted">
        // zero deps &middot; typescript &middot; touch &amp; mouse
      </p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href={`${base}getting-started`}
          class="inline-flex items-center px-6 py-3 rounded-full bg-gradient-to-r from-accent-indigo to-accent-cyan text-white font-semibold text-sm shadow-[0_0_24px_rgba(99,102,241,0.4)] hover:shadow-[0_0_32px_rgba(99,102,241,0.6)] transition-shadow"
        >
          Get Started &rarr;
        </a>
        <span class="glass inline-flex items-center px-5 py-3 rounded-full font-mono text-sm text-muted border border-border">
          npm i nipplejs
        </span>
      </div>
    </section>


  </main>

    <!-- Games Carousel — full viewport width -->
    <section class="pb-24" id="games-carousel">

      <!-- Arrows + track -->
      <div class="flex items-center px-4 max-w-6xl mx-auto">
        <!-- Prev (hidden on mobile) -->
        <button id="carousel-prev" class="hidden md:flex flex-shrink-0 cursor-pointer text-white/20 hover:text-white/50 transition-colors -mr-6 z-10" aria-label="Previous game">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <!-- Track wrapper — visible on desktop for neighbors, hidden on mobile -->
        <div class="flex-1 min-w-0 overflow-hidden md:overflow-visible">
          <div class="flex" id="carousel-track" style="transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);">
            {games.map((game, i) => (
              <div
                class="carousel-slide flex-shrink-0 px-1"
                style="transition: transform 0.5s ease, opacity 0.5s ease, filter 0.5s ease;"
                data-slide={i}
              >
                <JoystickDemo game={game.slug} highlight={game.highlights} title={game.name} description={game.description} badges={game.badges} />
              </div>
            ))}
          </div>
        </div>

        <!-- Next (hidden on mobile) -->
        <button id="carousel-next" class="hidden md:flex flex-shrink-0 cursor-pointer text-white/20 hover:text-white/50 transition-colors -ml-6 z-10" aria-label="Next game">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <!-- Dots + mobile arrows on same line -->
      <div class="flex justify-center items-center gap-4 mt-4" id="carousel-dots-row">
        <button id="carousel-prev-mobile" class="md:hidden cursor-pointer text-white/25 hover:text-white/50 transition-colors" aria-label="Previous game">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="flex gap-2" id="carousel-dots">
        {games.map((game, i) => (
          <button
            class:list={['w-2 h-2 rounded-full transition-all duration-300 cursor-pointer', i === 0 ? 'bg-accent-indigo w-6' : 'bg-muted/30']}
            data-dot={i}
            aria-label={`Go to ${game.name}`}
          />
        ))}
        </div>
        <button id="carousel-next-mobile" class="md:hidden cursor-pointer text-white/25 hover:text-white/50 transition-colors" aria-label="Next game">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <script>
        const track = document.getElementById('carousel-track')!;
        const dots = document.querySelectorAll<HTMLElement>('#carousel-dots [data-dot]');
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const prevBtnMobile = document.getElementById('carousel-prev-mobile');
        const nextBtnMobile = document.getElementById('carousel-next-mobile');
        const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
        const total = slides.length;
        const isMobile = window.matchMedia('(max-width: 767px)').matches;
        const isFirefox = navigator.userAgent.includes('Firefox');
        const SLIDE_PCT = isMobile ? 100 : 75;
        let current = 0;

        // Set slide widths
        slides.forEach((slide) => {
          slide.style.width = `${SLIDE_PCT}%`;
        });

        const CENTER_OFFSET = (100 - SLIDE_PCT) / 2;

        function goTo(index: number) {
          current = ((index % total) + total) % total;

          // Translate the track so current slide is centered
          track.style.transform = `translateX(calc(-${current * SLIDE_PCT}% + ${CENTER_OFFSET}%))`;

          // Style each slide — active is flat, neighbors are tilted and blurred
          // Set z-index on active immediately so it's on top during transition
          slides.forEach((slide, i) => {
            const diff = i - current;
            // Active slide above arrows (z-10), neighbors below
            slide.style.zIndex = diff === 0 ? '20' : '1';
          });

          // Use rAF to batch the animated properties so Firefox picks them up
          requestAnimationFrame(() => {
            slides.forEach((slide, i) => {
              const diff = i - current;
              if (diff === 0) {
                slide.style.opacity = '1';
                slide.style.transform = 'scale(1)';
                slide.style.filter = 'none';
                slide.style.pointerEvents = 'auto';
                slide.style.cursor = 'default';
              } else if (!isMobile && (Math.abs(diff) === 1 || Math.abs(diff) === total - 1)) {
                const isRight = diff === 1 || diff === -(total - 1);
                slide.style.opacity = '0.5';
                slide.style.transform = `scale(0.9) perspective(1000px) rotateY(${isRight ? '-8' : '8'}deg)`;
                slide.style.filter = isFirefox ? 'none' : 'blur(3px)';
                slide.style.pointerEvents = 'auto';
                slide.style.cursor = 'pointer';
              } else {
                slide.style.opacity = isMobile ? '0' : '0.15';
                slide.style.transform = 'scale(0.85)';
                slide.style.filter = (isMobile || isFirefox) ? 'none' : 'blur(5px)';
                slide.style.pointerEvents = 'none';
                slide.style.cursor = 'default';
              }
            });
          });

          // Dots
          dots.forEach((dot, i) => {
            if (i === current) {
              dot.classList.add('bg-accent-indigo', 'w-6');
              dot.classList.remove('bg-muted/30');
            } else {
              dot.classList.remove('bg-accent-indigo', 'w-6');
              dot.classList.add('bg-muted/30');
            }
          });

          // After transition ends (500ms), reposition active game's joysticks
          // and stop games on non-active slides to save performance
          setTimeout(() => {
            const activeGames: any[] = ((window as any).__nippleGames = (window as any).__nippleGames || []);
            const activeSlide = slides[current];
            for (let i = activeGames.length - 1; i >= 0; i--) {
              const g = activeGames[i];
              if (activeSlide && activeSlide.contains(g.container)) {
                g.collections.forEach((c: any) => c.reposition?.());
              } else {
                g.destroy();
                g.restore();
                activeGames.splice(i, 1);
              }
            }
          }, 550);
        }

        // Click neighbors to navigate
        slides.forEach((slide, i) => {
          slide.addEventListener('click', () => {
            if (i !== current) goTo(i);
          });
        });

        // Init — set initial styles without transition, then enable
        track.style.transition = 'none';
        goTo(0);
        // Force reflow then enable transition
        track.offsetHeight;
        track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';

        prevBtn?.addEventListener('click', () => goTo(current - 1));
        nextBtn?.addEventListener('click', () => goTo(current + 1));
        prevBtnMobile?.addEventListener('click', () => goTo(current - 1));
        nextBtnMobile?.addEventListener('click', () => goTo(current + 1));
        dots.forEach((dot) => {
          dot.addEventListener('click', () => goTo(Number(dot.dataset.dot)));
        });
      </script>
    </section>


</BaseLayout>
