---
import BaseLayout from '../layouts/BaseLayout.astro';
import JoystickDemo from '../components/JoystickDemo.astro';

const base = import.meta.env.BASE_URL;

const games = [
  {
    name: 'Neon Snake',
    slug: 'fog-explorer',
    description: 'Collect orbs to grow your glowing snake.',
    highlights: ['mode'],
    badges: ["mode: 'static'"],
  },
  {
    name: 'Asteroid Dodge',
    slug: 'asteroid-dodge',
    description: 'Dodge falling asteroids with horizontal-only movement.',
    highlights: ['lockX'],
    badges: ["lockX: true"],
  },
  {
    name: 'Dual-Stick Arena',
    slug: 'dual-stick-arena',
    description: 'Move and shoot with two joysticks. Best on mobile.',
    highlights: ['multitouch'],
    badges: ["multitouch: true"],
  },
  {
    name: 'Space Observatory',
    slug: 'endless-chase',
    description: 'Aim within the joystick, pan the sky by pushing beyond — two controls, one thumb.',
    highlights: ['follow'],
    badges: ['follow: true', 'baseDelta'],
  },
  {
    name: 'Space Drift',
    slug: 'space-drift',
    description: 'Set your heading and drift through space.',
    highlights: ['restJoystick'],
    badges: ["restJoystick: false"],
  },
];
---
<BaseLayout title="NippleJS — Virtual Joystick">
  <main class="max-w-5xl mx-auto px-6">

    <!-- Hero -->
    <section class="text-center py-28 relative">
      <!-- Logo with particles emitted from text -->
      <div class="flex items-center justify-center gap-5 mb-10 relative" id="hero-logo">
        <canvas id="logo-particles" class="absolute inset-0 w-full h-full pointer-events-none" style="z-index:0;"></canvas>
        <div class="relative z-[1] flex items-center gap-5">
          <div id="hero-joystick-back" class="w-28 h-28 rounded-full relative flex items-center justify-center" style="background: rgba(99,102,241,0.2);">
            <div id="hero-joystick-front" class="w-14 h-14 rounded-full absolute" style="background: linear-gradient(135deg, #a5b4fc, #6366f1); transition: transform 0.1s ease-out;"></div>
          </div>
          <span id="logo-text" class="text-heading font-bold text-6xl tracking-tight" style="text-shadow: 0 0 20px rgba(129,140,248,0.4), 0 0 40px rgba(99,102,241,0.2);">nipplejs</span>
        </div>
      </div>

      <script>
        // --- Particles emitted from the text bounding box ---
        const logoCanvas = document.getElementById('logo-particles') as HTMLCanvasElement;
        const logoText = document.getElementById('logo-text');
        const logoContainer = document.getElementById('hero-logo');
        if (logoCanvas && logoText && logoContainer) {
          const lctx = logoCanvas.getContext('2d')!;
          const colors = ['#818cf8', '#38bdf8', '#a78bfa', '#c7d2fe'];

          function resizeLogoCanvas() {
            const rect = logoContainer!.getBoundingClientRect();
            logoCanvas.width = rect.width;
            logoCanvas.height = rect.height;
          }
          resizeLogoCanvas();
          window.addEventListener('resize', resizeLogoCanvas);

          interface Particle {
            x: number; y: number;
            vx: number; vy: number;
            size: number; alpha: number;
            color: string; decay: number;
          }
          const parts: Particle[] = [];

          function getTextRect() {
            const containerRect = logoContainer!.getBoundingClientRect();
            const textRect = logoText!.getBoundingClientRect();
            return {
              x: textRect.left - containerRect.left,
              y: textRect.top - containerRect.top,
              w: textRect.width,
              h: textRect.height,
            };
          }

          function spawn() {
            const r = getTextRect();
            // Spawn along the edges and surface of the text
            const x = r.x + Math.random() * r.w;
            const y = r.y + Math.random() * r.h;

            parts.push({
              x,
              y,
              vx: (Math.random() - 0.5) * 0.08,
              vy: -(0.03 + Math.random() * 0.08),
              size: 0.5 + Math.random() * 1.5,
              alpha: 0.2 + Math.random() * 0.35,
              color: colors[Math.floor(Math.random() * colors.length)],
              decay: 0.0008 + Math.random() * 0.001,
            });
          }

          let f = 0;
          let logoVisible = true;
          let logoAnimId: number | null = null;

          function loop() {
            if (!logoVisible) { logoAnimId = null; return; }
            lctx.clearRect(0, 0, logoCanvas.width, logoCanvas.height);
            if (f % 4 === 0) spawn();

            for (let i = parts.length - 1; i >= 0; i--) {
              const p = parts[i];
              p.x += p.vx;
              p.y += p.vy;
              p.alpha -= p.decay;
              if (p.alpha <= 0) { parts.splice(i, 1); continue; }

              lctx.save();
              lctx.globalAlpha = p.alpha;
              lctx.shadowBlur = 6;
              lctx.shadowColor = p.color;
              lctx.fillStyle = p.color;
              lctx.beginPath();
              lctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
              lctx.fill();
              lctx.restore();
            }
            f++;
            logoAnimId = requestAnimationFrame(loop);
          }

          const logoObserver = new IntersectionObserver((entries) => {
            logoVisible = entries[0].isIntersecting;
            if (logoVisible && !logoAnimId) loop();
          });
          logoObserver.observe(logoContainer);
          loop();

          // --- Joystick front follows cursor ---
          const back = document.getElementById('hero-joystick-back');
          const front = document.getElementById('hero-joystick-front');
          if (back && front) {
            const maxDist = back.offsetWidth / 2; // front center can reach the back's edge
            document.addEventListener('mousemove', (e) => {
              const rect = back.getBoundingClientRect();
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              const dx = e.clientX - cx;
              const dy = e.clientY - cy;
              const dist = Math.sqrt(dx * dx + dy * dy);
              const clamp = Math.min(dist, maxDist) / (dist || 1);
              front.style.transform = `translate(${dx * clamp}px, ${dy * clamp}px)`;
            });
            document.addEventListener('mouseleave', () => {
              front.style.transform = 'translate(0px, 0px)';
            });
          }
        }
      </script>

      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight leading-tight">
        <span class="hero-title block relative" data-text="Virtual joysticks">
          <span class="hero-title-text">Virtual joysticks</span>
        </span>
        <span class="hero-title block relative mt-2" data-text="for the modern web">
          <span class="hero-title-text">for the modern web</span>
        </span>
      </h1>
      <p class="mt-6 font-mono text-sm text-muted">
        // zero deps &middot; typescript &middot; touch &amp; mouse
      </p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href={`${base}getting-started`}
          class="inline-flex items-center px-6 py-3 rounded-full bg-gradient-to-r from-accent-indigo to-accent-cyan text-white font-semibold text-sm shadow-[0_0_24px_rgba(99,102,241,0.4)] hover:shadow-[0_0_32px_rgba(99,102,241,0.6)] transition-shadow"
        >
          Get Started &rarr;
        </a>
        <span class="glass inline-flex items-center px-5 py-3 rounded-full font-mono text-sm text-muted border border-border">
          npm i nipplejs
        </span>
      </div>
    </section>


  </main>

    <!-- Games Carousel — full viewport width -->
    <section class="pb-24" id="games-carousel">
      <div class="max-w-5xl mx-auto px-6">
      <!-- Active game info -->
      <div class="text-center mb-6" id="carousel-info">
        <h3 class="text-heading text-2xl font-bold mb-2 transition-opacity duration-300" id="carousel-title">{games[0].name}</h3>
        <p class="text-body mb-3 transition-opacity duration-300" id="carousel-desc">{games[0].description}</p>
        <div class="flex flex-wrap gap-2 justify-center transition-opacity duration-300" id="carousel-badges">
          {games[0].badges.map((badge) => (
            <span class="glass px-3 py-1 text-xs font-mono text-muted">{badge}</span>
          ))}
        </div>
      </div>

      </div><!-- close max-w-5xl -->

      <!-- Arrows + track in a row — full viewport width -->
      <div class="flex items-center gap-4 px-4">
        <!-- Prev -->
        <button id="carousel-prev" class="flex-shrink-0 cursor-pointer text-white/15 hover:text-white/40 transition-colors" aria-label="Previous game">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>

        <!-- Track wrapper — overflow visible so neighbors show -->
        <div class="flex-1 min-w-0" style="overflow: visible;">
          <div class="flex" id="carousel-track" style="transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);">
            {games.map((game, i) => (
              <div
                class="carousel-slide flex-shrink-0 px-1"
                style="width: 75%; transition: transform 0.5s ease, opacity 0.5s ease; will-change: transform, opacity;"
                data-slide={i}
                data-name={game.name}
                data-desc={game.description}
                data-badges={JSON.stringify(game.badges)}
              >
                <JoystickDemo game={game.slug} highlight={game.highlights} />
              </div>
            ))}
          </div>
        </div>

        <!-- Next -->
        <button id="carousel-next" class="flex-shrink-0 cursor-pointer text-white/15 hover:text-white/40 transition-colors" aria-label="Next game">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>

      <!-- Dots -->
      <div class="flex justify-center gap-2 mt-6" id="carousel-dots">
        {games.map((game, i) => (
          <button
            class:list={['w-2 h-2 rounded-full transition-all duration-300 cursor-pointer', i === 0 ? 'bg-accent-indigo w-6' : 'bg-muted/30']}
            data-dot={i}
            aria-label={`Go to ${game.name}`}
          />
        ))}
      </div>

      <script>
        const track = document.getElementById('carousel-track')!;
        const dots = document.querySelectorAll<HTMLElement>('#carousel-dots [data-dot]');
        const prevBtn = document.getElementById('carousel-prev')!;
        const nextBtn = document.getElementById('carousel-next')!;
        const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
        const titleEl = document.getElementById('carousel-title')!;
        const descEl = document.getElementById('carousel-desc')!;
        const badgesEl = document.getElementById('carousel-badges')!;
        const total = slides.length;
        const SLIDE_PCT = 75; // each slide is 75% of track width
        let current = 0;

        // Center offset: to center the active slide, shift by (100 - 80) / 2 = 10%
        const CENTER_OFFSET = (100 - SLIDE_PCT) / 2;

        function goTo(index: number) {
          current = ((index % total) + total) % total;

          // Translate the track so current slide is centered
          track.style.transform = `translateX(calc(-${current * SLIDE_PCT}% + ${CENTER_OFFSET}%))`;

          // Style each slide — active is flat, neighbors are tilted and blurred
          slides.forEach((slide, i) => {
            const diff = i - current;
            if (diff === 0) {
              slide.style.opacity = '1';
              slide.style.transform = 'scale(1) perspective(1000px) rotateY(0deg)';
              slide.style.filter = 'none';
              slide.style.pointerEvents = 'auto';
              slide.style.zIndex = '2';
              slide.style.cursor = 'default';
            } else if (Math.abs(diff) === 1 || Math.abs(diff) === total - 1) {
              // Immediate neighbor
              const isRight = diff === 1 || diff === -(total - 1);
              slide.style.opacity = '0.35';
              slide.style.transform = `scale(0.88) perspective(1000px) rotateY(${isRight ? '-8' : '8'}deg)`;
              slide.style.filter = 'blur(2px)';
              slide.style.pointerEvents = 'auto';
              slide.style.zIndex = '1';
              slide.style.cursor = 'pointer';
            } else {
              slide.style.opacity = '0.1';
              slide.style.transform = 'scale(0.8)';
              slide.style.filter = 'blur(4px)';
              slide.style.pointerEvents = 'none';
              slide.style.zIndex = '0';
              slide.style.cursor = 'default';
            }
          });

          // Update text
          const active = slides[current];
          if (active) {
            titleEl.textContent = active.dataset.name || '';
            descEl.textContent = active.dataset.desc || '';
            const badges = JSON.parse(active.dataset.badges || '[]') as string[];
            badgesEl.textContent = '';
            badges.forEach((b) => {
              const span = document.createElement('span');
              span.className = 'glass px-3 py-1 text-xs font-mono text-muted';
              span.textContent = b;
              badgesEl.appendChild(span);
            });
          }

          // Dots
          dots.forEach((dot, i) => {
            if (i === current) {
              dot.classList.add('bg-accent-indigo', 'w-6');
              dot.classList.remove('bg-muted/30');
            } else {
              dot.classList.remove('bg-accent-indigo', 'w-6');
              dot.classList.add('bg-muted/30');
            }
          });

          // After transition ends (500ms), reposition active game's joysticks
          setTimeout(() => {
            const activeGames = (window as any).__nippleGames || [];
            for (const g of activeGames) {
              g.collections.forEach((c: any) => c.reposition?.());
            }
          }, 550);
        }

        // Click neighbors to navigate
        slides.forEach((slide, i) => {
          slide.addEventListener('click', () => {
            if (i !== current) goTo(i);
          });
        });

        // Init — set initial styles without transition, then enable
        track.style.transition = 'none';
        goTo(0);
        // Force reflow then enable transition
        track.offsetHeight;
        track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';

        prevBtn.addEventListener('click', () => goTo(current - 1));
        nextBtn.addEventListener('click', () => goTo(current + 1));
        dots.forEach((dot) => {
          dot.addEventListener('click', () => goTo(Number(dot.dataset.dot)));
        });
      </script>
    </section>


</BaseLayout>
